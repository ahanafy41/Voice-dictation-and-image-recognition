-- ### Screen Text and Screenshot Functions
function getTextFromScreen()
    if scrollForSummaryEnabled then return scrollAndCollectText() else
        local rootN = service.getRootInActiveWindow(); if rootN then local txtL={}; collectText(rootN,txtL); pcall(rootN.recycle,rootN); return table.concat(txtL," ") end; return ""
    end
end

function collectText(node, textList)
    if not node then return end
    local nT; local s=pcall(function() nT=node.getText() end); if s and nT and #tostring(nT)>0 then table.insert(textList,tostring(nT)) end
    local cC=0; s=pcall(function() cC=node.getChildCount() end); if not s then return end
    for i=0,cC-1 do local ch; s=pcall(function() ch=node.getChild(i) end); if s and ch then collectText(ch,textList); pcall(ch.recycle,ch) end end
end

function scrollAndCollectText()
    local allT={}; local colN={}; local function colCur() local r=service.getRootInActiveWindow(); if r then local sT={}; collectText(r,sT); local h=table.concat(sT,"|"); if not colN[h] then table.insert(allT,table.concat(sT," ")); colN[h]=true end; pcall(r.recycle,r); return true end; return false end
    colCur(); local rN=service.getRootInActiveWindow(); if not rN then return table.concat(allT," ") end
    local scrN=findScrollableNode(rN); pcall(rN.recycle,rN); if not scrN then return table.concat(allT," ") end
    local maxS=10; local sC=0
    while sC<maxS do
        local sSuc=false; local sRes=pcall(function() sSuc=scrN.performAction(AccessibilityNodeInfo.ACTION_SCROLL_FORWARD) end)
        if not sRes or not sSuc then break end; sC=sC+1; Thread.sleep(600)
        if not colCur() then break end
        local curR=service.getRootInActiveWindow(); if curR then local curS=findScrollableNode(curR); pcall(curR.recycle,curR)
            if not curS then break end
            if scrN~=curS then if scrN and scrN.recycle then pcall(scrN.recycle,scrN) end; scrN=curS else local v=pcall(function() return scrN.getClassName() end); if not v then break end end
        else break end
    end
    if scrN and scrN.recycle then pcall(scrN.recycle,scrN) end; return table.concat(allT," ")
end

function findScrollableNode(node)
    if not node then return nil end
    local isS=false; local cR=pcall(function() isS=node.isScrollable() end); if cR and isS then return node end
    local sCh=nil; local cC=0; cR=pcall(function() cC=node.getChildCount() end); if not cR then return nil end
    for i=0,cC-1 do local ch; cR=pcall(function() ch=node.getChild(i) end); if cR and ch then sCh=findScrollableNode(ch); if sCh then return sCh else pcall(ch.recycle,ch) end end end
    return nil
end

function takeScreenshotAndEncode(callback)
    local function procBmp(bmp) if bmp then local s,r=pcall(function() local b=ByteArrayOutputStream(); bmp.compress(Bitmap.CompressFormat.PNG,90,b); local iB=b.toByteArray(); b.close(); pcall(bmp.recycle,bmp); return Base64.encodeToString(iB,Base64.NO_WRAP) end); if s then callback(r) else if bmp and not bmp.isRecycled() then pcall(bmp.recycle,bmp) end; callback(nil) end else callback(nil) end end
    if screenshotMode=="focus" then local n=service.getFocusView(); if n then pcall(function() service.getScreenShot(n,{onScreenCaptureDone=procBmp}) end); pcall(n.recycle,n) else pcall(function() service.getScreenShot({onScreenCaptureDone=procBmp}) end) end else pcall(function() service.getScreenShot({onScreenCaptureDone=procBmp}) end) end
end


