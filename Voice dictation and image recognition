function testGeminiApiKey(key, modelIdToTest, callback)
    local currentDictLangDetails = getLanguageDetails(selectedLanguage)
    if not key or key == "" then callback(false, getFeedbackString("error_gemini_api_test_fail_empty", currentDictLangDetails.code)); return end
    if not modelIdToTest or modelIdToTest == "" then callback(false, getFeedbackString("error_gemini_api_test_fail_model", currentDictLangDetails.code)); return end

    service.asyncSpeak(getFeedbackString("command_processing", currentDictLangDetails.code, "API test with " .. modelIdToTest))
    local p = "Hello"; local u = "https://generativelanguage.googleapis.com/v1beta/models/"..modelIdToTest..":generateContent?key="..key
    local rB = [[{ "contents": [{ "parts": [ {"text": "]]..escapeJsonString(p)..[["} ] }] }]]
    local h = {["Content-Type"]="application/json"}
    Http.post(u,rB,h, function(s,r)
        local msg_for_callback
        if s==200 then
            local ok,jR=pcall(function() return JSONObject(r) end)
            if ok and jR and jR.has("candidates") and jR.getJSONArray("candidates").length()>0 then
                msg_for_callback = getFeedbackString("error_gemini_api_test_success", currentDictLangDetails.code, modelIdToTest)
                callback(true, msg_for_callback)
                return
            end
            msg_for_callback = getFeedbackString("error_gemini_api_test_fail_response", currentDictLangDetails.code, modelIdToTest)
            callback(false, msg_for_callback)
        elseif s==400 then
            msg_for_callback = getFeedbackString("error_gemini_api_test_fail_400", currentDictLangDetails.code, modelIdToTest)
            callback(false, msg_for_callback)
        elseif s==403 then
            msg_for_callback = getFeedbackString("error_gemini_api_test_fail_403", currentDictLangDetails.code, modelIdToTest)
            callback(false, msg_for_callback)
        elseif s==429 then
            msg_for_callback = getFeedbackString("error_gemini_api_test_fail_429", currentDictLangDetails.code, modelIdToTest)
            callback(false, msg_for_callback)
        else
            msg_for_callback = getFeedbackString("error_gemini_api_test_fail_other", currentDictLangDetails.code, modelIdToTest, s)
            callback(false, msg_for_callback)
        end
    end)
end

