-- .luacheckrc
globals = {
  "service",
  "import",
  "require",
  "Http",
  "Thread",
  "Runnable",
  "URL",
  "BufferedReader",
  "InputStreamReader",
  "android",
  "java",
  "org",
  "com",
  "collectgarbage",

  -- Android UI Components
  "LinearLayout",
  "TextView",
  "EditText",
  "Button",
  "RadioGroup",
  "RadioButton",
  "Spinner",
  "ArrayAdapter",
  "ScrollView",
  "Gravity",
  "Typeface",
  "View",
  "WindowManager",
  "PixelFormat",
  "ArrayList",

  -- Android Classes
  "TextToSpeech",
  "SpeechRecognizer",
  "RecognizerIntent",
  "Intent",
  "Locale",
  "Settings",
  "AdapterView",
  "AccessibilityNodeInfo",
  "Context",
  "Base64",
  "Bitmap",
  "ByteArrayOutputStream",
  "JSONObject",
  "RecognitionListener",

  -- System Called
  "onDestroy"
}
